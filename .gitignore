#Powered by seedance 4.0
# ========================= 通用基础规则 =========================
# 临时文件
*.tmp
*.temp
*.swp
*~
.DS_Store       # macOS 系统文件
Thumbs.db       # Windows 系统文件
desktop.ini     # Windows 配置文件

# 日志文件
*.log
logs/
log/

# 缓存文件
*.cache
.cache/
__pycache__/    # Python 缓存
node_modules/   # Node.js 依赖（前端/Node 项目保留，其他可删）
vendor/         # Composer 依赖（PHP 项目保留，其他可删）

# 编译/构建产物
dist/
build/
out/
target/         # Java/Maven 产物
bin/
obj/

# 环境变量/敏感配置
.env
.env.local
.env.*.local
config/local.yml
config/local.json
*.pem
*.key

# ========================= 编辑器/IDE 配置 =========================
# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json  # 如需共享基础配置，可取消注释前面的!
.idea/          # IntelliJ IDEA/WebStorm
*.sublime-*     # Sublime Text
.project        # Eclipse
.classpath      # Eclipse
.settings/      # Eclipse

# ========================= 编程语言专属（按需保留） =========================
# Python
*.py[cod]
*.so
.Python
env/
venv/
*.egg-info/
.coverage

# Java
*.class
*.jar
*.war
*.ear
.gradle/
.mvn/

# JavaScript/TypeScript
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Go
*.exe
*.dll
*.so
*.dylib
vendor/

# C/C++
*.o
*.a
*.so